# Dynatrace MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Your Dynatrace Platform URL
# Use the new Platform URL format (apps.dynatrace.com), NOT classic URLs (live.dynatrace.com)
DT_ENVIRONMENT=https://YOUR_ENVIRONMENT_ID.apps.dynatrace.com

# Authentication Option 1: Platform Token (recommended for simple setups)
# Create a Platform Token in Dynatrace: Settings > Access Tokens > Platform Tokens
# Required scopes: app-engine:apps:run, storage:logs:read, storage:events:read, 
#                  storage:spans:read, storage:bizevents:read, storage:metrics:read,
#                  storage:entities:read
# Optional RUM scopes: storage:user.sessions:read, storage:user.events:read
DT_PLATFORM_TOKEN=YOUR_PLATFORM_TOKEN_HERE

# Authentication Option 2: OAuth Client (for advanced scenarios)
# Create an OAuth Client in Dynatrace: Account Management > Identity & Access Management > OAuth Clients
# Required scopes: same as above
# OAUTH_CLIENT_ID=YOUR_OAUTH_CLIENT_ID_HERE
# OAUTH_CLIENT_SECRET=YOUR_OAUTH_CLIENT_SECRET_HERE

# Optional: Override SSO URL (usually auto-discovered)
# DT_SSO_URL=https://sso.dynatrace.com

# Optional: Grail Query Budget (default: 1000 GB)
DT_GRAIL_QUERY_BUDGET_GB=1000

# ─── Feature Flags ───────────────────────────────────────────────────────────
# These flags control AI assistant behaviour. Set to "yes" or "no".

# Grail-Only Mode: When "yes", AI will ONLY use Gen 3 Grail DQL queries.
# When "no", AI may also use Gen 2 APIs (USQL, classic config reads) if a
# Gen 2 token (DT_GEN2_API_TOKEN) is provided below.
MCP_GRAIL_ONLY=yes

# User Variable: When "yes", AI will resolve MCP_USER_ID at session start
# and include it on all tracking events. When "no", user.id is omitted.
MCP_USE_USER_VARIABLE=yes

# Send Tracking Events: When "yes", AI will send a CUSTOM_INFO event to
# Dynatrace after every MCP query for cost/usage monitoring.
# When "no", tracking events are skipped entirely.
MCP_SEND_TRACKING_EVENTS=yes

# ─── User Identity ───────────────────────────────────────────────────────────
# Only used when MCP_USE_USER_VARIABLE=yes
# This value is sent with every tracking event to identify the user
# Note: Using MCP_USER_ID instead of USER to avoid conflict with system env var
MCP_USER_ID=your.email@company.com

# ─── Gen 2 API (Optional) ────────────────────────────────────────────────────
# Only used when MCP_GRAIL_ONLY=no
# Classic environment URL (live.dynatrace.com format)
# DT_CLASSIC_ENVIRONMENT=https://YOUR_ENVIRONMENT_ID.live.dynatrace.com

# Gen 2 API Token — scopes: ReadConfig, DTAQLAccess, settings.read
# Used for: USQL queries, session/action properties, Gen 2 config reads
# DT_GEN2_API_TOKEN=YOUR_GEN2_API_TOKEN_HERE
