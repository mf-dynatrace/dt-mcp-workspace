# Environment files with secrets
.env
.env.local
.env.*.local
.env.backup-*

# Keep the example file
!.env.example

# Custom instructions (tenant-specific, user-edited)
# Template is tracked; actual file is local-only
custom-instructions.md
!custom-instructions.template.md

# Reference files (tenant-specific, auto-populated by AI sessions)
# Templates are tracked; actual reference files are local-only
reference/*.md
!reference/*.template.md

# Migration backups
.reference-backup-*

# Generated reports (tenant-specific)
report/

# Node modules (if any local development)
node_modules/

# OS files
.DS_Store
Thumbs.db

# IDE files
*.swp
*.swo
*~
