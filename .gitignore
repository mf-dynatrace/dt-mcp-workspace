# Environment files with secrets
.env
.env.local
.env.*.local
.env.backup-*

# Keep the example file
!.env.example

# Custom instructions (tenant-specific, user-edited)
# Template is tracked; actual file is local-only
custom-instructions.md
!custom-instructions.template.md

# Reference files (tenant-specific, auto-populated by AI sessions)
# Templates are tracked; actual reference files are local-only
reference/*.md
!reference/*.template.md

# Migration backups
.reference-backup-*
.custom-instructions.backup-*

# Generated reports (tenant-specific)
report/

# User-generated content (dashboards, workflows, prompts created during sessions)
local/
prompt.md
*.prompt.local.md
AI Dash Gen Prompt.md

# User-generated examples (client dashboards, injectors created during sessions)
# Tracked repo examples are unaffected — gitignore only applies to untracked files
example/*.json
example/*.workflow.json
example/*.yaml
example/*_README.md

# Old flat skill files (superseded by skills/*/SKILL.md subdirectories)
skills/*.md

# User agent/tool configs
.agents/
.claude/*
!.claude/settings.json

# Node modules (if any local development)
node_modules/

# OS files
.DS_Store
Thumbs.db

# IDE files
*.swp
*.swo
*~
