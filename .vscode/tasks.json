{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Auto-pull latest updates",
      "type": "shell",
      "command": "git pull --ff-only 2>/dev/null || true",
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Initialize reference files",
      "type": "shell",
      "command": "bash setup.sh",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
