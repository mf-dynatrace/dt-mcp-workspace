{"version":20,"variables":[],"tiles":{"0":{"type":"markdown","content":"# 🔍 MCP Query Usage & Cost Dashboard\n\nReal-time monitoring of Dynatrace MCP query execution, data consumption, and budget tracking across all users.\n\n**Data Source:** Events `event.name == \"MCP Query Execution\"` sent via `send_event` after each MCP tool call."},"1":{"title":"Total Queries","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| summarize queries = count()","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"QUERIES","recordField":"queries","colorThresholdTarget":"background"},"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"2":{"title":"Data Scanned (GB)","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| summarize data_gb = sum(toDouble(query.bytes_scanned))","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"DATA SCANNED","recordField":"data_gb","colorThresholdTarget":"background"},"thresholds":[],"unitsOverrides":[{"identifier":"data_gb","unitCategory":"unspecified","baseUnit":"count","displayUnit":null,"decimals":2,"suffix":" GB","delimiter":true,"added":1766081789473}]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"3":{"title":"Estimated Cost (USD)","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| summarize cost = sum(toDouble(query.cost_usd))","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"COST","recordField":"cost","colorThresholdTarget":"background","prefixIcon":"MoneyIcon"},"thresholds":[],"unitsOverrides":[{"identifier":"cost","unitCategory":"unspecified","baseUnit":"count","displayUnit":null,"decimals":4,"suffix":" USD","delimiter":true,"added":1766081789473}]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"4":{"title":"Budget Used (%)","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| sort timestamp desc\n| limit 1\n| fields pct = toDouble(budget.percentage_used)","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"BUDGET USED","recordField":"pct","colorThresholdTarget":"background"},"thresholds":[{"id":1,"field":"pct","title":"","isEnabled":true,"rules":[{"id":1,"color":{"Default":"#4FD5B0"},"comparator":"<","value":75},{"id":2,"color":{"Default":"#F8B000"},"comparator":"≥","value":75},{"id":3,"color":{"Default":"#C62239"},"comparator":"≥","value":90}]}],"unitsOverrides":[{"identifier":"pct","unitCategory":"percentage","baseUnit":"percent","displayUnit":null,"decimals":1,"suffix":"%","delimiter":true,"added":1766081789473}]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"5":{"title":"Active Users","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| summarize users = countDistinct(user.id)","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"USERS","recordField":"users","colorThresholdTarget":"background","prefixIcon":"UserIcon"},"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"6":{"title":"Success Rate (%)","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| summarize success_rate = (countIf(query.success == \"true\") * 100.0) / count()","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"SUCCESS RATE","recordField":"success_rate","colorThresholdTarget":"background"},"thresholds":[{"id":1,"field":"success_rate","title":"","isEnabled":true,"rules":[{"id":1,"color":{"Default":"#4FD5B0"},"comparator":"≥","value":95},{"id":2,"color":{"Default":"#F8B000"},"comparator":"≥","value":80},{"id":3,"color":{"Default":"#C62239"},"comparator":"<","value":80}]}],"unitsOverrides":[{"identifier":"success_rate","unitCategory":"percentage","baseUnit":"percent","displayUnit":null,"decimals":1,"suffix":"%","delimiter":true,"added":1766081789473}]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"7":{"title":"","type":"data","query":"data record(a=\"Query Trends\")","visualization":"singleValue","visualizationSettings":{"singleValue":{"labelMode":"none","isIconVisible":true,"prefixIcon":"GraphBarVerticalIcon","colorThresholdTarget":"background"},"autoSelectVisualization":false,"thresholds":[{"id":1,"field":"a","title":"","isEnabled":true,"rules":[{"id":1,"color":"#2AB6F4","comparator":"!=","value":"0"}]}]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"8":{"title":"📈 Query Volume Over Time","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| makeTimeseries queries = count(), bins:50","visualization":"lineChart","visualizationSettings":{"chartSettings":{"fieldMapping":{"leftAxisValues":["queries"],"timestamp":"timeframe"},"seriesOverrides":[{"seriesId":["queries"],"override":{"color":"#2AB6F4"}}],"legend":{"position":"bottom"}},"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"9":{"title":"💾 Data Consumption Over Time (GB)","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| makeTimeseries data_scanned_gb = sum(toDouble(query.bytes_scanned)), bins:50","visualization":"areaChart","visualizationSettings":{"chartSettings":{"fieldMapping":{"leftAxisValues":["data_scanned_gb"],"timestamp":"timeframe"},"seriesOverrides":[{"seriesId":["data_scanned_gb"],"override":{"color":"#7C38BC"}}],"legend":{"position":"bottom"}},"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"10":{"title":"💰 Cost Trend (USD)","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| makeTimeseries cost_usd = sum(toDouble(query.cost_usd)), bins:50","visualization":"lineChart","visualizationSettings":{"chartSettings":{"fieldMapping":{"leftAxisValues":["cost_usd"],"timestamp":"timeframe"},"seriesOverrides":[{"seriesId":["cost_usd"],"override":{"color":"#FF6900"}}],"legend":{"position":"bottom"}},"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"11":{"title":"","type":"data","query":"data record(a=\"User Analytics\")","visualization":"singleValue","visualizationSettings":{"singleValue":{"labelMode":"none","isIconVisible":true,"prefixIcon":"UserGroupIcon","colorThresholdTarget":"background"},"autoSelectVisualization":false,"thresholds":[{"id":1,"field":"a","title":"","isEnabled":true,"rules":[{"id":1,"color":"#7C38BC","comparator":"!=","value":"0"}]}]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"12":{"title":"👥 Top Users by Data Consumption (GB)","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| summarize data_gb = sum(toDouble(query.bytes_scanned)), queries = count(), by:{user.id}\n| sort data_gb desc\n| limit 10","visualization":"categoricalBarChart","visualizationSettings":{"autoSelectVisualization":false,"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"13":{"title":"👤 Top Users by Query Count","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| summarize queries = count(), data_gb = sum(toDouble(query.bytes_scanned)), by:{user.id}\n| sort queries desc\n| limit 10","visualization":"categoricalBarChart","visualizationSettings":{"autoSelectVisualization":false,"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"14":{"title":"📊 User Query Efficiency (GB per Query)","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| summarize total_gb = sum(toDouble(query.bytes_scanned)), query_count = count(), by:{user.id}\n| fieldsAdd efficiency = total_gb / query_count\n| sort efficiency desc\n| limit 10\n| fields user.id, efficiency, query_count, total_gb","visualization":"table","visualizationSettings":{"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"15":{"title":"","type":"data","query":"data record(a=\"Query Analysis\")","visualization":"singleValue","visualizationSettings":{"singleValue":{"labelMode":"none","isIconVisible":true,"prefixIcon":"SearchIcon","colorThresholdTarget":"background"},"autoSelectVisualization":false,"thresholds":[{"id":1,"field":"a","title":"","isEnabled":true,"rules":[{"id":1,"color":"#FF6900","comparator":"!=","value":"0"}]}]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"16":{"title":"🎯 Query Source Distribution","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| summarize count(), by:{query.source}","visualization":"donutChart","visualizationSettings":{"chartSettings":{"circleChartSettings":{"valueType":"relative","showTotalValue":true},"legend":{"position":"bottom"}},"legend":{"ratio":27},"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"17":{"title":"🔧 Tool Usage Distribution","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| summarize count(), by:{query.tool}","visualization":"donutChart","visualizationSettings":{"chartSettings":{"circleChartSettings":{"valueType":"relative","showTotalValue":true},"legend":{"position":"bottom"}},"legend":{"ratio":27},"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"18":{"title":"🔍 Data Object Distribution","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| filter isNotNull(query.data_object)\n| summarize queries = count(), data_gb = sum(toDouble(query.bytes_scanned)), by:{query.data_object}\n| sort data_gb desc","visualization":"categoricalBarChart","visualizationSettings":{"autoSelectVisualization":false,"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"19":{"title":"💸 Most Expensive Queries (Top 10)","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| sort toDouble(query.bytes_scanned) desc\n| limit 10\n| fields timestamp, user.id, query.dql, query.bytes_scanned, query.cost_usd, query.tool","visualization":"table","visualizationSettings":{"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"20":{"title":"📋 All Query Activity (Recent)","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| sort timestamp desc\n| limit 50\n| fields timestamp, user.id, query.tool, query.data_object, query.bytes_scanned, query.cost_usd, query.records_scanned, query.records_returned, query.success","visualization":"table","visualizationSettings":{"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"21":{"title":"📊 Records Scanned vs Returned","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| makeTimeseries scanned = sum(toDouble(query.records_scanned)), returned = sum(toDouble(query.records_returned)), bins:50","visualization":"lineChart","visualizationSettings":{"chartSettings":{"fieldMapping":{"leftAxisValues":["scanned","returned"],"timestamp":"timeframe"},"seriesOverrides":[{"seriesId":["scanned"],"override":{"color":"#C62239"}},{"seriesId":["returned"],"override":{"color":"#4FD5B0"}}],"legend":{"position":"bottom"}},"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"22":{"title":"❌ Failed Queries","type":"data","query":"fetch events\n| filter event.type == \"CUSTOM_INFO\" and event.name == \"MCP Query Execution\"\n| filter query.success == \"false\"\n| sort timestamp desc\n| limit 20\n| fields timestamp, user.id, query.dql, query.tool","visualization":"table","visualizationSettings":{"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"23":{"type":"markdown","content":"## 🚨 Budget Alerts\n\n### Threshold