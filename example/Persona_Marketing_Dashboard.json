    "9": {
      "title": "🔻 Booking Funnel (Session Drop-Off)",
      "type": "data",
      "query": "fetch user.events, from:$dt_timeframe_from, to:$dt_timeframe_to\n| filter dt.rum.application.entity == \"APPLICATION-XXXXXXXXXXXX\" and characteristics.classifier == \"page_summary\"\n| filter page.url.path == \"/your-location/\" or page.url.path == \"/your-location/products/store/\" or page.url.path == \"/your/bookings/\" or page.url.path == \"/your/bookings/thank-you-for-your-booking/\"\n| fieldsAdd funnel_step = toString(if(page.url.path == \"/your-location/\", \"1. Homepage\",\n  else: if(page.url.path == \"/your-location/products/store/\", \"2. Tickets Page\",\n  else: if(page.url.path == \"/your/bookings/\", \"3. Bookings\",\n  else: \"4. Confirmation\"))))\n| summarize sessions = toDouble(countDistinct(dt.rum.session.id)), by:{funnel_step}\n| sort funnel_step asc\n| fieldsAdd timeframe = now()",
      "visualization": "barChart",
      "visualizationSettings": {
        "chartSettings": {
          "fieldMapping": {
            "timestamp": "timeframe",
            "categoryAxisValues": ["funnel_step"],
            "leftAxisValues": ["sessions"]
          },
          "categoricalBarChartSettings": {
            "layout": "horizontal"
          },
          "seriesOverrides": [
            {
              "seriesId": ["sessions"],
              "override": {
                "color": "#FF6900"
              }
            }
          ],
          "legend": { "position": "hidden" }
        },
        "thresholds": [],
        "unitsOverrides": []
      },
      "querySettings": {
        "maxResultRecords": 1000,
        "defaultScanLimitGbytes": 500,
        "maxResultMegaBytes": 100,
        "defaultSamplingRatio": 10,
        "enableSampling": false
      },
      "davis": {
        "enabled": false,
        "davisVisualization": {
          "isAvailable": true
        }
      }
    },
    "10": {
      "title": "📈 Daily Conversion Rate (Confirmations / Homepage %)",
      "type": "data",
      "query": "fetch user.events, from:$dt_timeframe_from, to:$dt_timeframe_to\n| filter dt.rum.application.entity == \"APPLICATION-XXXXXXXXXXXX\" and characteristics.classifier == \"page_summary\"\n| filter page.url.path == \"/your-location/\" or page.url.path == \"/your/bookings/thank-you-for-your-booking/\"\n| fieldsAdd is_homepage = if(page.url.path == \"/your-location/\", 1, else: 0), is_confirmation = if(page.url.path == \"/your/bookings/thank-you-for-your-booking/\", 1, else: 0)\n| makeTimeseries homepage_views = sum(is_homepage), confirmation_views = sum(is_confirmation), interval:1d\n| fieldsAdd conversion_rate = (confirmation_views[] / homepage_views[]) * 100",
      "visualization": "lineChart",
