    "2": {
      "title": "👥 Total Sessions",
      "type": "data",
      "query": "fetch user.sessions, from:$dt_timeframe_from, to:$dt_timeframe_to\n| filter in(dt.rum.application.entities, \"APPLICATION-XXXXXXXXXXXX\")\n| summarize sessions = count()",
      "visualization": "singleValue",
      "visualizationSettings": {
        "singleValue": {
          "label": "SESSIONS",
          "recordField": "sessions",
          "colorThresholdTarget": "background",
          "sparklineSettings": { "isVisible": false },
          "trend": { "isVisible": false }
