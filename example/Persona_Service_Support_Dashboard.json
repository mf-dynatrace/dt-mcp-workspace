    "13": {
      "title": "📊 Booking Flow — Step Completion & Error Rate",
      "type": "data",
      "query": "fetch user.events, from:$dt_timeframe_from, to:$dt_timeframe_to\n| filter dt.rum.application.entity == \"APPLICATION-XXXXXXXXXXXX\" and characteristics.classifier == \"request\"\n| filter matchesValue(toString(view.url.path), \"*/bookings/\") and view.url.path != \"/your/bookings/manage-my-bookings/\" and view.url.path != \"/your/bookings/thank-you-for-your-booking/\"\n| filter url.path == \"/api/packages/definitions\" or url.path == \"/api/seasons/getAll\" or url.path == \"/api/hotel/list\" or url.path == \"/api/hotel/details\" or url.path == \"/api/masterdata/getAttractionsAvailabilityInfo\"\n| fieldsAdd spa_step = if(url.path == \"/api/packages/definitions\", \"1. Start Booking\",\n  else: if(url.path == \"/api/seasons/getAll\", \"2. Select Dates\",\n  else: if(url.path == \"/api/hotel/list\", \"3. Choose Hotel\",\n  else: if(url.path == \"/api/hotel/details\", \"4. Select Room\",\n  else: \"5. Add Tickets\"))))\n| summarize sessions = countDistinct(dt.rum.session.id), requests = count(), errors = countIf(toDouble(http.response.status_code) >= 400), avg_ms = avg(duration) / 1000000, by:{spa_step}\n| fieldsAdd error_rate_pct = round(toDouble(errors) / toDouble(requests) * 100, decimals: 2)\n| sort spa_step asc",
      "visualization": "table",
      "visualizationSettings": {
        "thresholds": [
          {
