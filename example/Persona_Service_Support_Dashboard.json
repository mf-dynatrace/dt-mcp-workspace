    "6": {
      "title": "📈 Daily Error-Impacted Sessions vs Clean Sessions",
      "type": "data",
      "query": "fetch user.sessions, from:$dt_timeframe_from, to:$dt_timeframe_to\n| filter in(dt.rum.application.entities, \"APPLICATION-XXXXXXXXXXXX\")\n| fieldsAdd has_error = if(error.count > 0, 1, else: 0), clean = if(error.count == 0, 1, else: 0)\n| makeTimeseries error_sessions = sum(has_error), clean_sessions = sum(clean), interval:1d",
      "visualization": "barChart",
      "visualizationSettings": {
        "chartSettings": {
          "fieldMapping": {
            "timestamp": "timeframe",
            "leftAxisValues": ["error_sessions", "clean_sessions"]
          },
          "categoricalBarChartSettings": {
            "layout": "stacked"
          },
          "seriesOverrides": [
            { "seriesId": ["error_sessions"], "override": { "color": "#C62239" } },
            { "seriesId": ["clean_sessions"], "override": { "color": "#4FD5B0" } }
          ],
          "legend": { "position": "bottom" },
          "leftYAxisSettings": { "label": "Sessions" }
        },
        "thresholds": [],
        "unitsOverrides": []
      },
      "querySettings": {
        "maxResultRecords": 1000,
        "defaultScanLimitGbytes": 500,
        "maxResultMegaBytes": 100,
        "defaultSamplingRatio": 10,
        "enableSampling": false
      },
      "davis": {
        "enabled": false,
        "davisVisualization": {
          "isAvailable": true
        }
      }
