      "query": "fetch user.events, from:$dt_timeframe_from, to:$dt_timeframe_to\n| filter dt.rum.application.entity == \"APPLICATION-XXXXXXXXXXXX\" and characteristics.classifier == \"view_summary\"\n| filter isNotNull(web_vitals.largest_contentful_paint)\n| summarize Samples = count(), P75_LCP_ms = percentile(web_vitals.largest_contentful_paint, 75) / 1000000, P75_FCP_ms = percentile(web_vitals.first_contentful_paint, 75) / 1000000, P75_INP_ms = percentile(web_vitals.interaction_to_next_paint, 75) / 1000000, P75_TTFB_ms = percentile(web_vitals.time_to_first_byte, 75) / 1000000, P75_CLS = percentile(web_vitals.cumulative_layout_shift, 75), by:{view.detected_name}\n| filter Samples >= 30\n| sort P75_LCP_ms desc\n| limit 15",
      "visualization": "table",
