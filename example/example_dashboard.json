{"version":20,"variables":[],"tiles":{"0":{"type":"markdown","content":"# 📊 [CLIENT_NAME] - Business KPIs Dashboard\n\nReal-time business metrics covering:\n- **Key Performance Indicators** - Revenue, orders, conversion rate\n- **Trend Analysis** - Performance over time\n- **Operational Health** - Service reliability and performance\n\n> Replace `[CLIENT_NAME]` and queries with your actual BizEvent types and fields.\n> See `BizEvents_Reference.md` for available event types."},"1":{"title":"💷 Revenue (Total)","type":"data","query":"fetch bizevents, from:now()-7d\n| filter event.type == \"your.order.event.type\"\n| summarize totalRevenue = sum(order_value)","visualization":"singleValue","visualizationSettings":{"autoSelectVisualization":false,"singleValue":{"label":"REVENUE","recordField":"totalRevenue","colorThresholdTarget":"background","sparklineSettings":{"isVisible":false},"trend":{"isVisible":false}},"thresholds":[],"unitsOverrides":[{"identifier":"totalRevenue","unitCategory":"currency","baseUnit":"gbp","displayUnit":null,"decimals":2,"suffix":"","delimiter":true,"added":1766081789473}]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"2":{"title":"📦 Total Orders","type":"data","query":"fetch bizevents, from:now()-7d\n| filter event.type == \"your.order.event.type\"\n| summarize totalOrders = count()","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"ORDERS","recordField":"totalOrders","colorThresholdTarget":"background"},"thresholds":[],"unitsOverrides":[{"identifier":"totalOrders","unitCategory":"unspecified","baseUnit":"count","displayUnit":null,"decimals":0,"suffix":"","delimiter":true,"added":1766081789473}]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"3":{"title":"✅ Success Rate (%)","type":"data","query":"fetch bizevents, from:now()-7d\n| filter event.type == \"your.order.event.type\"\n| summarize success = countIf(status == \"success\"), total = count()\n| fieldsAdd successRate = (toDouble(success) / toDouble(total)) * 100","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"SUCCESS RATE","recordField":"successRate","colorThresholdTarget":"background"},"thresholds":[{"id":1,"field":"successRate","title":"","isEnabled":true,"rules":[{"id":1,"color":{"Default":"#4FD5B0"},"comparator":"≥","value":95},{"id":2,"color":{"Default":"#F8B000"},"comparator":"≥","value":85},{"id":3,"color":{"Default":"#C62239"},"comparator":"<","value":85}]}],"unitsOverrides":[{"identifier":"successRate","unitCategory":"percentage","baseUnit":"percent","displayUnit":null,"decimals":1,"suffix":"%","delimiter":true,"added":1766081789473}]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"4":{"title":"📈 Orders Over Time","type":"data","query":"fetch bizevents, from:now()-7d\n| filter event.type == \"your.order.event.type\"\n| makeTimeseries orders = count(), bins:50","visualization":"lineChart","visualizationSettings":{"chartSettings":{"fieldMapping":{"leftAxisValues":["orders"],"timestamp":"timeframe"},"seriesOverrides":[{"seriesId":["orders"],"override":{"color":"#2AB6F4"}}],"legend":{"position":"bottom"}},"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"5":{"title":"💷 Revenue Over Time","type":"data","query":"fetch bizevents, from:now()-7d\n| filter event.type == \"your.order.event.type\"\n| makeTimeseries revenue = sum(order_value), bins:50","visualization":"areaChart","visualizationSettings":{"chartSettings":{"fieldMapping":{"leftAxisValues":["revenue"],"timestamp":"timeframe"},"seriesOverrides":[{"seriesId":["revenue"],"override":{"color":"#7C38BC"}}],"legend":{"position":"bottom"}},"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"6":{"title":"📊 Orders by Category","type":"data","query":"fetch bizevents, from:now()-7d\n| filter event.type == \"your.order.event.type\"\n| summarize orders = count(), by:{category}\n| sort orders desc","visualization":"donutChart","visualizationSettings":{"chartSettings":{"circleChartSettings":{"valueType":"relative","showTotalValue":true},"legend":{"position":"bottom"}},"legend":{"ratio":27},"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"7":{"title":"🌐 Service Performance","type":"data","query":"timeseries {\n  requests = sum(dt.service.request.count),\n  failures = sum(dt.service.request.failure_count)\n}, from:now()-7d, interval:6h, filter:{dt.entity.service == \"SERVICE-XXXXXXXXXXXX\"}","visualization":"lineChart","visualizationSettings":{"chartSettings":{"fieldMapping":{"leftAxisValues":["requests","failures"],"timestamp":"timeframe"},"seriesOverrides":[{"seriesId":["requests"],"override":{"color":"#2AB6F4"}},{"seriesId":["failures"],"override":{"color":"#C62239"}}],"legend":{"position":"bottom"}},"thresholds":[],"unitsOverrides":[]},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualizati